{
  "_comment": "Qwen-Image-Edit 2511 background-replacement workflow. Uses the standard pattern: EmptyLatent + denoise=1.0, with the input image fed into TextEncodeQwenImageEdit so the model understands it as an edit, not a from-scratch generation. Keep prompts short and imperative.",
  "5": {
    "class_type": "EmptyLatentImage",
    "inputs": {
      "width": "${width}",
      "height": "${height}",
      "batch_size": 1
    }
  },
  "10": {
    "class_type": "UNETLoader",
    "inputs": {
      "unet_name": "qwen_image_edit_2511_fp8_e4m3fn.safetensors",
      "weight_dtype": "default"
    }
  },
  "11": {
    "class_type": "CLIPLoader",
    "inputs": {
      "clip_name": "qwen_2.5_vl_7b_fp8_scaled.safetensors",
      "type": "qwen_image"
    }
  },
  "12": {
    "class_type": "VAELoader",
    "inputs": {
      "vae_name": "qwen_image_vae.safetensors"
    }
  },
  "13": {
    "class_type": "ModelSamplingAuraFlow",
    "inputs": {
      "model": ["10", 0],
      "shift": 3.1
    }
  },
  "20": {
    "class_type": "LoadImage",
    "inputs": {
      "image": "${input_image}"
    }
  },
  "30": {
    "class_type": "TextEncodeQwenImageEdit",
    "inputs": {
      "clip": ["11", 0],
      "vae": ["12", 0],
      "image": ["20", 0],
      "prompt": "${prompt}"
    }
  },
  "31": {
    "class_type": "TextEncodeQwenImageEdit",
    "inputs": {
      "clip": ["11", 0],
      "vae": ["12", 0],
      "image": ["20", 0],
      "prompt": "${negative_prompt}"
    }
  },
  "40": {
    "class_type": "KSampler",
    "inputs": {
      "model": ["13", 0],
      "seed": "${seed}",
      "steps": 20,
      "cfg": 4.0,
      "sampler_name": "euler",
      "scheduler": "simple",
      "positive": ["30", 0],
      "negative": ["31", 0],
      "latent_image": ["5", 0],
      "denoise": 1.0
    }
  },
  "50": {
    "class_type": "VAEDecode",
    "inputs": {
      "samples": ["40", 0],
      "vae": ["12", 0]
    }
  },
  "60": {
    "class_type": "SaveImage",
    "inputs": {
      "images": ["50", 0],
      "filename_prefix": "ermbg_probe"
    }
  }
}
