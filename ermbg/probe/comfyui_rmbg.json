{
  "_comment": "RMBG baseline via ComfyUI's rembg node. Uses isnet-general-use (RMBG-1.4-equivalent IS-Net) with alpha-matting on. Output: RGBA PNG.",
  "10": {
    "class_type": "LoadImage",
    "inputs": {
      "image": "${input_image}"
    }
  },
  "20": {
    "class_type": "Image Rembg (Remove Background)",
    "inputs": {
      "images": ["10", 0],
      "transparency": true,
      "model": "isnet-general-use",
      "post_processing": false,
      "only_mask": false,
      "alpha_matting": true,
      "alpha_matting_foreground_threshold": 240,
      "alpha_matting_background_threshold": 10,
      "alpha_matting_erode_size": 10,
      "background_color": "none"
    }
  },
  "30": {
    "class_type": "SaveImage",
    "inputs": {
      "images": ["20", 0],
      "filename_prefix": "ermbg_rmbg_baseline"
    }
  }
}
