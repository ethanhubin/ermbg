{
  "_comment": "Prompt-aware ownership mask workflow: LoadImage -> CLIPSeg Masking -> ERMBG AutoMatte(subject_mask). This template is rendered locally and can be submitted to the remote ComfyUI server once it is idle.",
  "10": {
    "class_type": "LoadImage",
    "inputs": {
      "image": "${input_image}"
    }
  },
  "15": {
    "class_type": "CLIPSeg Model Loader",
    "inputs": {
      "model": "${clipseg_model}"
    }
  },
  "20": {
    "class_type": "CLIPSeg Masking",
    "inputs": {
      "image": ["10", 0],
      "text": "${subject_prompt}",
      "clipseg_model": ["15", 0]
    }
  },
  "30": {
    "class_type": "ErmbgAutoMatte",
    "inputs": {
      "image": ["10", 0],
      "despill": "auto (router decides)",
      "use_keyer": "auto (router decides)",
      "bg_color": "${bg_color}",
      "matting_model": "${matting_model}",
      "subject_mask": ["20", 0]
    }
  },
  "40": {
    "class_type": "SaveImage",
    "inputs": {
      "images": ["30", 0],
      "filename_prefix": "${filename_prefix}_foreground"
    }
  },
  "50": {
    "class_type": "Convert Masks to Images",
    "inputs": {
      "masks": ["30", 1]
    }
  },
  "60": {
    "class_type": "SaveImage",
    "inputs": {
      "images": ["50", 0],
      "filename_prefix": "${filename_prefix}_alpha"
    }
  },
  "70": {
    "class_type": "Convert Masks to Images",
    "inputs": {
      "masks": ["20", 0]
    }
  },
  "80": {
    "class_type": "SaveImage",
    "inputs": {
      "images": ["70", 0],
      "filename_prefix": "${filename_prefix}_subject_mask"
    }
  }
}
