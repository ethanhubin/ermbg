{
  "_comment": "Full ERMBG matte on remote ComfyUI: LoadImage -> ErmbgAutoMatte -> save foreground and alpha.",
  "10": {
    "class_type": "LoadImage",
    "inputs": {
      "image": "${input_image}"
    }
  },
  "20": {
    "class_type": "ErmbgAutoMatte",
    "inputs": {
      "image": ["10", 0],
      "despill": "${despill}",
      "use_keyer": "${use_keyer}",
      "bg_color": "${bg_color}",
      "matting_model": "${matting_model}",
      "shadow_mode": "${shadow_mode}"
    }
  },
  "30": {
    "class_type": "SaveImage",
    "inputs": {
      "images": ["20", 0],
      "filename_prefix": "${filename_prefix}_foreground"
    }
  },
  "40": {
    "class_type": "Convert Masks to Images",
    "inputs": {
      "masks": ["20", 1]
    }
  },
  "50": {
    "class_type": "SaveImage",
    "inputs": {
      "images": ["40", 0],
      "filename_prefix": "${filename_prefix}_alpha"
    }
  }
}
